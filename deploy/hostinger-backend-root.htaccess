# Rename/copy to: public_html/backend/.htaccess
# Use when Laravel lives at public_html/backend/ with folders app/, vendor/, public/, …
# Routes all HTTP traffic into the public/ folder (real web root).

<IfModule mod_rewrite.c>
    Options +FollowSymLinks -Indexes
    RewriteEngine On
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
